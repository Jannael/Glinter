        "generationData": {
          "status": "done",
          "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>GLINTER - The best way to use git</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;500&display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #0a0a0a;\n            color: #e4e4e7;\n        }\n        .mono {\n            font-family: 'JetBrains Mono', monospace;\n        }\n        .border-glow:hover {\n            border-color: #3f3f46;\n            box-shadow: 0 0 15px rgba(255, 255, 255, 0.05);\n        }\n        .terminal-dot {\n            width: 12px;\n            height: 12px;\n            border-radius: 50%;\n        }\n    </style>\n</head>\n<body class=\"p-6 md:p-12 lg:p-20 flex justify-center\">\n\n    <!-- Main Container -->\n    <main class=\"max-w-6xl w-full border border-zinc-800 rounded-[2rem] p-8 md:p-16 relative overflow-hidden\">\n        \n        <!-- Header Section -->\n        <header class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 mb-24\">\n            <div class=\"space-y-8\">\n                <h1 class=\"text-6xl md:text-8xl font-extrabold tracking-tighter text-white uppercase italic\">\n                    GLINTER\n                </h1>\n                <div class=\"space-y-2\">\n                    <p class=\"text-xl font-semibold text-zinc-300\">The best way to use git!</p>\n                    <p class=\"text-zinc-500 max-w-sm\">Wrapper of git, improve your experience using git with enhanced commands and safety checks.</p>\n                </div>\n\n                <!-- Install Card -->\n                <div class=\"inline-block group cursor-pointer\">\n                    <div class=\"border border-zinc-700 rounded-2xl p-6 bg-zinc-900/50 backdrop-blur-sm border-glow transition-all\">\n                        <p class=\"text-xs uppercase tracking-widest text-zinc-500 mb-3 font-bold\">Installation</p>\n                        <code class=\"mono text-sm md:text-base text-zinc-200 flex items-center gap-3\">\n                            <span class=\"text-zinc-500\">$</span> bun add -g glinter-cli\n                            <i data-lucide=\"copy\" class=\"w-4 h-4 text-zinc-600 group-hover:text-white transition-colors\"></i>\n                        </code>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Features Timeline -->\n            <div class=\"relative pl-8 flex flex-col justify-center\">\n                <div class=\"absolute left-[7px] top-4 bottom-4 w-[1px] bg-zinc-800\"></div>\n                <ul class=\"space-y-6\">\n                    <li class=\"relative flex items-center gap-4 group\">\n                        <div class=\"absolute -left-[29px] w-2.5 h-2.5 rounded-full bg-zinc-800 border border-zinc-600 group-hover:bg-white transition-colors\"></div>\n                        <span class=\"text-zinc-400 group-hover:text-white transition-colors\">Set alias with one command</span>\n                    </li>\n                    <li class=\"relative flex items-center gap-4 group\">\n                        <div class=\"absolute -left-[29px] w-2.5 h-2.5 rounded-full bg-zinc-800 border border-zinc-600 group-hover:bg-white transition-colors\"></div>\n                        <span class=\"text-zinc-400 group-hover:text-white transition-colors\"><code class=\"mono text-zinc-300\">git add</code> improved</span>\n                    </li>\n                    <li class=\"relative flex items-center gap-4 group\">\n                        <div class=\"absolute -left-[29px] w-2.5 h-2.5 rounded-full bg-zinc-800 border border-zinc-600 group-hover:bg-white transition-colors\"></div>\n                        <span class=\"text-zinc-400 group-hover:text-white transition-colors\"><code class=\"mono text-zinc-300\">git commit</code> improved</span>\n                    </li>\n                    <li class=\"relative flex items-center gap-4 group\">\n                        <div class=\"absolute -left-[29px] w-2.5 h-2.5 rounded-full bg-zinc-800 border border-zinc-600 group-hover:bg-white transition-colors\"></div>\n                        <span class=\"text-zinc-400 group-hover:text-white transition-colors\"><code class=\"mono text-zinc-300\">git switch</code> improved</span>\n                    </li>\n                    <li class=\"relative flex items-center gap-4 group\">\n                        <div class=\"absolute -left-[29px] w-2.5 h-2.5 rounded-full bg-zinc-800 border border-zinc-600 group-hover:bg-white transition-colors\"></div>\n                        <span class=\"text-zinc-400 group-hover:text-white transition-colors\">Avoid staging sensitive files like <code class=\"mono text-zinc-300\">.env</code></span>\n                    </li>\n                </ul>\n            </div>\n        </header>\n\n        <!-- Main Content Section -->\n        <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start mb-24\">\n            \n            <!-- Table Card -->\n            <div class=\"lg:col-span-5 space-y-4\">\n                <h3 class=\"text-zinc-500 font-medium italic\">Tabla con alias</h3>\n                <div class=\"border border-zinc-800 rounded-3xl p-1 bg-zinc-900/20\">\n                    <div class=\"overflow-hidden rounded-[1.4rem] border border-zinc-800 bg-black\">\n                        <table class=\"w-full text-left text-sm\">\n                            <thead class=\"bg-zinc-900/50 border-b border-zinc-800\">\n                                <tr>\n                                    <th class=\"px-4 py-3 font-semibold text-zinc-300\">Alias</th>\n                                    <th class=\"px-4 py-3 font-semibold text-zinc-300\">Command</th>\n                                </tr>\n                            </thead>\n                            <tbody class=\"divide-y divide-zinc-900\">\n                                <tr class=\"hover:bg-zinc-900/30 transition-colors\">\n                                    <td class=\"px-4 py-3 mono text-blue-400\">gaa</td>\n                                    <td class=\"px-4 py-3 text-zinc-500 italic\">git add .</td>\n                                </tr>\n                                <tr class=\"hover:bg-zinc-900/30 transition-colors\">\n                                    <td class=\"px-4 py-3 mono text-blue-400\">gc</td>\n                                    <td class=\"px-4 py-3 text-zinc-500 italic\">git commit -m</td>\n                                </tr>\n                                <tr class=\"hover:bg-zinc-900/30 transition-colors\">\n                                    <td class=\"px-4 py-3 mono text-blue-400\">gps</td>\n                                    <td class=\"px-4 py-3 text-zinc-500 italic\">git push</td>\n                                </tr>\n                                <tr class=\"hover:bg-zinc-900/30 transition-colors\">\n                                    <td class=\"px-4 py-3 mono text-blue-400\">gpl</td>\n                                    <td class=\"px-4 py-3 text-zinc-500 italic\">git pull</td>\n                                </tr>\n                                <tr class=\"hover:bg-zinc-900/30 transition-colors\">\n                                    <td class=\"px-4 py-3 mono text-blue-400\">gst</td>\n                                    <td class=\"px-4 py-3 text-zinc-500 italic\">git status</td>\n                                </tr>\n                            </tbody>\n                        </table>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Terminal Mockup -->\n            <div class=\"lg:col-span-7\">\n                <div class=\"bg-[#0d0d0d] border border-zinc-800 rounded-xl overflow-hidden shadow-2xl\">\n                    <!-- Terminal Header -->\n                    <div class=\"bg-zinc-900/80 px-4 py-3 border-b border-zinc-800 flex items-center justify-between\">\n                        <div class=\"flex gap-2\">\n                            <div class=\"terminal-dot bg-red-500/50\"></div>\n                            <div class=\"terminal-dot bg-yellow-500/50\"></div>\n                            <div class=\"terminal-dot bg-green-500/50\"></div>\n                        </div>\n                        <span class=\"text-xs text-zinc-500 mono\">bash — glinter</span>\n                        <div class=\"w-12\"></div>\n                    </div>\n                    <!-- Terminal Body -->\n                    <div class=\"p-6 mono text-xs md:text-sm leading-relaxed overflow-x-auto\">\n                        <div class=\"mb-4\">\n                            <span class=\"text-zinc-500\">$</span> <span class=\"text-white\">npx glinter init</span>\n                        </div>\n                        <div class=\"text-zinc-400 border border-zinc-800 p-3 mb-4 inline-block\">\n                            <p class=\"text-yellow-500 font-bold\">glinter <span class=\"text-zinc-500 font-normal\">v1.0.2</span></p>\n                            <p>Auto-configure the best git experience</p>\n                        </div>\n                        <p class=\"text-blue-400 mb-2\">• Detected technologies:</p>\n                        <div class=\"grid grid-cols-3 gap-2 mb-4 text-zinc-500\">\n                            <div class=\"flex items-center gap-1\"><span class=\"text-green-500\">✓</span> Next.js</div>\n                            <div class=\"flex items-center gap-1\"><span class=\"text-green-500\">✓</span> React</div>\n                            <div class=\"flex items-center gap-1\"><span class=\"text-green-500\">✓</span> Tailwind</div>\n                        </div>\n                        <p class=\"text-blue-400 mb-2\">• Suggested Aliases (11):</p>\n                        <div class=\"space-y-1 mb-4\">\n                            <p class=\"text-zinc-300\">1. <span class=\"text-zinc-500\">g-commit-safe</span> → Enhanced commit</p>\n                            <p class=\"text-zinc-300\">2. <span class=\"text-zinc-500\">g-push-force-never</span> → Safety push</p>\n                            <p class=\"text-zinc-300\">3. <span class=\"text-zinc-500\">g-clean-branches</span> → Auto-prune</p>\n                        </div>\n                        <p class=\"animate-pulse\">Install 11 aliases? [Y/n] <span class=\"bg-white text-black px-1\">Y</span></p>\n                        <div class=\"mt-4 text-green-500\">\n                            <p>✓ Configured .gitconfig</p>\n                            <p>✓ Added safety hooks</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Footer Section -->\n        <footer class=\"grid grid-cols-1 md:grid-cols-3 gap-8 pt-12 border-t border-zinc-800\">\n            <div class=\"text-center md:text-left py-4 border-y border-zinc-800 md:border-none\">\n                <p class=\"text-zinc-400 uppercase tracking-widest text-xs mb-1\">Status</p>\n                <p class=\"font-bold text-white uppercase italic\">GLINTER is <br> open source</p>\n            </div>\n            \n            <div class=\"text-center py-4 border-y border-zinc-800 md:border-x md:border-y-0\">\n                <p class=\"text-zinc-400 uppercase tracking-widest text-xs mb-1\">Credits</p>\n                <div class=\"flex flex-col items-center gap-1\">\n                    <p class=\"font-bold text-white uppercase italic\">With the effort of <br> JANNAEL</p>\n                    <div class=\"flex gap-2 mt-1\">\n                        <i data-lucide=\"diamond\" class=\"w"
