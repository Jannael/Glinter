        "generationData": {
          "status": "done",
          "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>GLINTER - The best way to use git</title>\n    <script src=\"https://cdn.tailwindcss.com\"></script>\n    <script src=\"https://unpkg.com/lucide@latest\"></script>\n    <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Fira+Code:wght@400;500&display=swap\" rel=\"stylesheet\">\n    <style>\n        body {\n            font-family: 'Inter', sans-serif;\n            background-color: #0a0a0a;\n            color: #ededed;\n        }\n        .code-font {\n            font-family: 'Fira Code', monospace;\n        }\n        .terminal-shadow {\n            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);\n        }\n        .timeline-line::before {\n            content: '';\n            position: absolute;\n            left: 7px;\n            top: 24px;\n            bottom: 0;\n            width: 2px;\n            background: #27272a;\n        }\n        .glass-card {\n            background: rgba(255, 255, 255, 0.03);\n            border: 1px solid rgba(255, 255, 255, 0.1);\n            backdrop-filter: blur(10px);\n        }\n    </style>\n</head>\n<body class=\"min-h-screen selection:bg-zinc-700\">\n\n    <main class=\"max-w-6xl mx-auto px-6 py-12 lg:py-24\">\n        \n        <!-- Hero Section -->\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-start mb-32\">\n            <div>\n                <h1 class=\"text-7xl font-extrabold tracking-tighter mb-4 bg-gradient-to-r from-white to-zinc-500 bg-clip-text text-transparent\">\n                    GLINTER\n                </h1>\n                <p class=\"text-xl text-zinc-400 font-medium mb-2\">The best way to use git!</p>\n                <p class=\"text-zinc-500 mb-8 max-w-md\">Wrapper of git, improve your experience using git with streamlined commands and safer defaults.</p>\n                \n                <!-- Install Card -->\n                <div class=\"glass-card rounded-xl p-6 relative group overflow-hidden\">\n                    <div class=\"flex items-center justify-between mb-4\">\n                        <span class=\"text-xs font-bold uppercase tracking-widest text-zinc-500\">Installation</span>\n                        <div class=\"flex gap-1.5\">\n                            <div class=\"w-2.5 h-2.5 rounded-full bg-zinc-800\"></div>\n                            <div class=\"w-2.5 h-2.5 rounded-full bg-zinc-800\"></div>\n                        </div>\n                    </div>\n                    <div class=\"space-y-3\">\n                        <div class=\"flex items-center justify-between bg-black/40 p-3 rounded-lg border border-white/5 hover:border-white/10 transition-colors group/cmd\">\n                            <code class=\"code-font text-sm text-zinc-300\">bun add -g glinter</code>\n                            <button class=\"text-zinc-500 hover:text-white transition-colors\"><i data-lucide=\"copy\" class=\"w-4 h-4\"></i></button>\n                        </div>\n                        <div class=\"flex items-center justify-between bg-black/40 p-3 rounded-lg border border-white/5 hover:border-white/10 transition-colors group/cmd\">\n                            <code class=\"code-font text-sm text-zinc-300\">npm install -g glinter</code>\n                            <button class=\"text-zinc-500 hover:text-white transition-colors\"><i data-lucide=\"copy\" class=\"w-4 h-4\"></i></button>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- Features Timeline -->\n            <div class=\"space-y-8 pt-4\">\n                <div class=\"relative pl-8 timeline-line\">\n                    <div class=\"absolute left-0 top-1.5 w-4 h-4 rounded-full border-2 border-zinc-400 bg-black z-10\"></div>\n                    <h3 class=\"text-lg font-semibold\">Set alias with one command</h3>\n                    <p class=\"text-zinc-500 text-sm\">Configure your workflow instantly without touching .gitconfig</p>\n                </div>\n                <div class=\"relative pl-8 timeline-line\">\n                    <div class=\"absolute left-0 top-1.5 w-4 h-4 rounded-full border-2 border-zinc-600 bg-black z-10\"></div>\n                    <h3 class=\"text-lg font-semibold text-zinc-300\">Git add improved</h3>\n                    <p class=\"text-zinc-500 text-sm\">Interactive staging with better visual feedback</p>\n                </div>\n                <div class=\"relative pl-8 timeline-line\">\n                    <div class=\"absolute left-0 top-1.5 w-4 h-4 rounded-full border-2 border-zinc-600 bg-black z-10\"></div>\n                    <h3 class=\"text-lg font-semibold text-zinc-300\">Git commit improved</h3>\n                    <p class=\"text-zinc-500 text-sm\">Templates and conventional commit helpers built-in</p>\n                </div>\n                <div class=\"relative pl-8 timeline-line\">\n                    <div class=\"absolute left-0 top-1.5 w-4 h-4 rounded-full border-2 border-zinc-600 bg-black z-10\"></div>\n                    <h3 class=\"text-lg font-semibold text-zinc-300\">Git switch improved</h3>\n                    <p class=\"text-zinc-500 text-sm\">Fuzzy search through your branches</p>\n                </div>\n                <div class=\"relative pl-8\">\n                    <div class=\"absolute left-0 top-1.5 w-4 h-4 rounded-full border-2 border-zinc-800 bg-black z-10\"></div>\n                    <h3 class=\"text-lg font-semibold text-zinc-400\">Avoid staging sensitive files</h3>\n                    <p class=\"text-zinc-500 text-sm\">Automatic protection for .env and secrets</p>\n                </div>\n            </div>\n        </div>\n\n        <!-- Middle Section -->\n        <section class=\"mb-32\">\n            <h2 class=\"text-center text-zinc-500 uppercase tracking-[0.3em] text-sm font-bold mb-12\">Tabla con alias</h2>\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8\">\n                <!-- Alias Card -->\n                <div class=\"glass-card rounded-2xl p-8 border-zinc-800/50\">\n                    <div class=\"space-y-6\">\n                        <div class=\"flex justify-between items-center border-b border-zinc-800 pb-4\">\n                            <span class=\"code-font text-emerald-500\">gs</span>\n                            <span class=\"text-zinc-400\">git status -sb</span>\n                        </div>\n                        <div class=\"flex justify-between items-center border-b border-zinc-800 pb-4\">\n                            <span class=\"code-font text-emerald-500\">ga</span>\n                            <span class=\"text-zinc-400\">git add .</span>\n                        </div>\n                        <div class=\"flex justify-between items-center border-b border-zinc-800 pb-4\">\n                            <span class=\"code-font text-emerald-500\">gc</span>\n                            <span class=\"text-zinc-400\">git commit -m</span>\n                        </div>\n                        <div class=\"flex justify-between items-center border-b border-zinc-800 pb-4\">\n                            <span class=\"code-font text-emerald-500\">gp</span>\n                            <span class=\"text-zinc-400\">git push origin</span>\n                        </div>\n                        <div class=\"flex justify-between items-center\">\n                            <span class=\"code-font text-emerald-500\">gl</span>\n                            <span class=\"text-zinc-400\">git log --oneline</span>\n                        </div>\n                    </div>\n                </div>\n\n                <!-- Terminal Mockup -->\n                <div class=\"bg-[#121212] rounded-xl overflow-hidden terminal-shadow border border-zinc-800\">\n                    <div class=\"bg-[#1e1e1e] px-4 py-3 flex items-center gap-2 border-b border-zinc-800\">\n                        <div class=\"w-3 h-3 rounded-full bg-[#ff5f56]\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-[#ffbd2e]\"></div>\n                        <div class=\"w-3 h-3 rounded-full bg-[#27c93f]\"></div>\n                        <span class=\"ml-4 text-xs text-zinc-500 code-font\">glinter — bash</span>\n                    </div>\n                    <div class=\"p-6 code-font text-sm leading-relaxed\">\n                        <div class=\"mb-2\">\n                            <span class=\"text-zinc-500\">$</span> <span class=\"text-white\">glinter status</span>\n                        </div>\n                        <div class=\"text-zinc-400 mb-4\">\n                            Detected technologies: <br>\n                            <span class=\"text-emerald-500\">✓</span> React &nbsp;&nbsp; <span class=\"text-emerald-500\">✓</span> Tailwind CSS\n                        </div>\n                        <div class=\"text-zinc-300\">\n                            1. vercel-react-best-practices <span class=\"text-zinc-600\">→ React</span><br>\n                            2. next-cache-components <span class=\"text-zinc-600\">→ Next.js</span><br>\n                            3. tailwind-css-patterns <span class=\"text-zinc-600\">→ Tailwind</span>\n                        </div>\n                        <div class=\"mt-4 text-white\">\n                            Install 3 skills? [Y/n] <span class=\"animate-pulse\">_</span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- Footer -->\n        <footer class=\"border-t border-zinc-900 pt-16\">\n            <div class=\"grid grid-cols-1 md:grid-cols-3 gap-12\">\n                <div class=\"space-y-4\">\n                    <h4 class=\"text-zinc-400 font-bold uppercase text-xs tracking-widest\">Open Source</h4>\n                    <p class=\"text-zinc-500 text-sm leading-relaxed\">GLINTER is open source and community driven. Contributions are welcome.</p>\n                    <a href=\"#\" class=\"inline-flex items-center gap-2 text-white hover:text-zinc-400 transition-colors\">\n                        <i data-lucide=\"github\" class=\"w-5 h-5\"></i>\n                        <span>Github</span>\n                    </a>\n                </div>\n\n                <div class=\"space-y-4\">\n                    <h4 class=\"text-zinc-400 font-bold uppercase text-xs tracking-widest\">Creator</h4>\n                    <p class=\"text-zinc-500 text-sm leading-relaxed\">Built with the effort of JANNAEL. Focused on DX and terminal productivity.</p>\n                    <div class=\"flex gap-4\">\n                        <a href=\"#\" class=\"text-white hover:text-zinc-400 transition-colors\">Jannael</a>\n                        <div class=\"flex gap-2\">\n                            <div class=\"w-6 h-6 border border-zinc-700 rotate-45 flex items-center justify-center hover:bg-white hover:text-black transition-all cursor-pointer\">\n                                <i data-lucide=\"twitter\" class=\"w-3 h-3 -rotate-45\"></i>\n                            </div>\n                            <div class=\"w-6 h-6 border border-zinc-700 rotate-45 flex items-center justify-center hover:bg-white hover:text-black transition-all cursor-pointer\">\n                                <i data-lucide=\"globe\" class=\"w-3 h-3 -rotate-45\"></i>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"flex flex-col justify-end items-end\">\n                    <div class=\"text-right\">\n                        <p class=\"text-xs text-zinc-700 code-font\">v1.2.0-stable</p>\n                        <p class=\"text-xs text-zinc-800 mt-1\">© 2024 Glinter CLI</p>\n                    </div>\n                </div>\n            </div>\n        </footer>\n    </main>\n\n    <script>\n        // Initialize Lucide icons\n        lucide.createIcons();\n    </script>\n</body>\n</html>"
        }
      }
    },
