---
import CopyButton from '@/components/copy-button.astro'
import TerminalAnimation from '@/components/terminal-animation.astro'
---

<section class="flex flex-col lg:flex-row items-center justify-center min-h-screen lg:h-screen gap-10 lg:gap-20 px-6 lg:px-0 py-16 lg:py-0">
  <article class="prose text-secondary w-full lg:w-1/2 flex flex-col gap-3 justify-center items-center lg:items-start text-center lg:text-left lg:h-full">
    <h1 class="text-secondary text-5xl sm:text-7xl lg:text-9xl mb-0">GLINTER</h1>
    <p class="text-xl sm:text-2xl lg:text-3xl -mb-4 text-secondary/70">
      A fast git workflow CLI for daily development.
    </p>
    <p class="text-base lg:text-lg mb-2 text-secondary/50">
      Glinter is a git alias tool that upgrades your terminal flow with interactive git add, safer defaults, and streamlined Git commands.
    </p>
    <CopyButton />
  </article>

  <TerminalAnimation />
</section>
