---
import CopyButton from '@/components/copy-button.astro'
import TerminalAnimation from '@/components/terminal-animation.astro'
import HeroStats from '@/components/hero-stats.astro'
import HeroStatsServer from '@/components/hero-stats-server.astro'
---

<section class="flex flex-col lg:flex-row items-center justify-center min-h-screen lg:h-screen gap-10 lg:gap-20 px-6 lg:px-0 py-16 lg:py-0 max-w-7xl mx-auto">
  <article class="prose text-secondary flex flex-col gap-3 justify-center items-center lg:items-start text-center lg:text-left lg:h-full">
    <h1 class="text-secondary text-5xl sm:text-7xl lg:text-9xl mb-0 mt-10">GLINTER</h1>
    <p class="text-xl sm:text-2xl lg:text-3xl -mb-4 text-secondary/70">
      The best way to use Git.
    </p>
    <p class="text-base lg:text-lg mb-2 text-secondary/50">
      Glinter reduces errors while using Git by providing interactive commands and safer defaults.
    </p>
    <div class="flex items-center gap-6 flex-col lg:flex-row lg:items-end">
      <CopyButton />
      <HeroStatsServer>
        <HeroStats stats={{
          stars: 100,
          weeklyDownloads: 100,
          totalDownloads: 100,
        }}/>
      </HeroStatsServer>
    </div>
  </article>

  <TerminalAnimation />
</section>
