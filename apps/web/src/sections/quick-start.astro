<section id="quick-start" class="mb-10 flex items-center justify-center px-6 py-5 lg:mt-10 lg:mb-30 lg:px-0 lg:py-0">
	<div class="prose prose-p:my-0 mx-auto flex w-full max-w-7xl flex-col gap-8">
		<div class="flex flex-col gap-3">
			<h2 class="text-secondary text-3xl font-bold lg:text-4xl">Quick Start</h2>
			<p class="text-secondary/60 text-lg">Install Glinter, run setup, and start using your Git aliases in seconds.</p>
		</div>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
			<article class="border-secondary/10 rounded-xl border bg-zinc-900/40 p-6">
				<p class="text-secondary/50 mb-3 text-xs tracking-widest uppercase">Step 1</p>
				<h3 class="text-secondary mb-3 text-xl font-semibold">Install</h3>
				<code class="text-secondary/90 block rounded bg-zinc-950 px-3 py-2 text-sm">npm i -g @jannael/glinter</code>
			</article>

			<article class="border-secondary/10 rounded-xl border bg-zinc-900/40 p-6">
				<p class="text-secondary/50 mb-3 text-xs tracking-widest uppercase">Step 2</p>
				<h3 class="text-secondary mb-3 text-xl font-semibold">Setup</h3>
				<code class="text-secondary/90 block rounded bg-zinc-950 px-3 py-2 text-sm">g setup</code>
			</article>

			<article class="border-secondary/10 rounded-xl border bg-zinc-900/40 p-6">
				<p class="text-secondary/50 mb-3 text-xs tracking-widest uppercase">Step 3</p>
				<h3 class="text-secondary mb-3 text-xl font-semibold">Use</h3>
				<code class="text-secondary/90 block rounded bg-zinc-950 px-3 py-2 text-sm">ga</code>
			</article>
		</div>
	</div>
</section>
