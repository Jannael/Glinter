<section
	id="quick-start"
	class="flex items-center justify-center px-6 py-5 lg:px-0 lg:py-0 mb-10 lg:mb-30 lg:mt-10"
>
	<div class="mx-auto flex w-full max-w-7xl flex-col gap-8 prose prose-p:my-0">
		<div class="flex flex-col gap-3">
			<h2 class="text-3xl lg:text-4xl font-bold text-secondary">Quick Start</h2>
			<p class="text-secondary/60 text-lg">
				Install Glinter, run setup, and start using your Git aliases in seconds.
			</p>
		</div>

		<div class="grid grid-cols-1 gap-6 md:grid-cols-3">
			<article class="rounded-xl border border-secondary/10 bg-zinc-900/40 p-6">
				<p class="mb-3 text-xs uppercase tracking-widest text-secondary/50">Step 1</p>
				<h3 class="mb-3 text-xl font-semibold text-secondary">Install</h3>
				<code class="block rounded bg-zinc-950 px-3 py-2 text-sm text-secondary/90">npm i -g @jannael/glinter</code>
			</article>

			<article class="rounded-xl border border-secondary/10 bg-zinc-900/40 p-6">
				<p class="mb-3 text-xs uppercase tracking-widest text-secondary/50">Step 2</p>
				<h3 class="mb-3 text-xl font-semibold text-secondary">Setup</h3>
				<code class="block rounded bg-zinc-950 px-3 py-2 text-sm text-secondary/90">g setup</code>
			</article>

			<article class="rounded-xl border border-secondary/10 bg-zinc-900/40 p-6">
				<p class="mb-3 text-xs uppercase tracking-widest text-secondary/50">Step 3</p>
				<h3 class="mb-3 text-xl font-semibold text-secondary">Use</h3>
				<code class="block rounded bg-zinc-950 px-3 py-2 text-sm text-secondary/90">ga</code>
			</article>
		</div>
	</div>
</section>
