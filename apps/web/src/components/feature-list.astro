---
const features = [
	{
		title: 'Git alias tool setup in one command',
		description: 'Configure your workflow instantly without touching .gitconfig',
	},
	{
		title: 'Interactive git add',
		description: 'Interactive staging with better visual feedback',
	},
	{
		title: 'Git commit improved',
		description: 'Templates and conventional commit helpers built-in',
	},
	{
		title: 'Git switch improved',
		description: 'Fuzzy search through your branches',
	},
	{
		title: 'Avoid staging sensitive files',
		description: 'Automatic protection for .env and secrets',
	},
]
---

<ul class="flex h-full w-full flex-col gap-0 font-sans">
	{
		features.map((feature, index) => (
			<li class="group relative flex items-start gap-5 pb-9 last:pb-0">
				{/* Decorative line connecting items */}
				{index !== features.length - 1 && <div class="bg-secondary/10 absolute top-6 bottom-0 left-[11px] w-[2px]" />}

				{/* Circle Icon */}
				<div class="relative z-10 mt-0.5 shrink-0">
					<div class="border-secondary/10 group-hover:border-secondary/80 h-6 w-6 rounded-full border-2 bg-transparent transition-colors" />
				</div>

				{/* Text Content */}
				<div class="flex flex-col">
					<h3 class="text-secondary hover:text-secondary/80 text-lg font-semibold transition-colors">{feature.title}</h3>
					<p class="text-secondary/60 mt-0.5 text-[15px]">{feature.description}</p>
				</div>
			</li>
		))
	}
</ul>
