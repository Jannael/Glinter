---
import ChartSvg from '@/assets/chart.svg?raw'
import DownloadSvg from '@/assets/download.svg?raw'
import StarSvg from '@/assets/star.svg?raw'
import { REPO_API, STARS_CACHE_TTL_SECONDS, STATS_CACHE_TTL_SECONDS, TOTAL_DOWNLOADS_API, WEEKLY_DOWNLOADS_API } from '@/constants'
import { formatStat, readJson } from '@/utils/utils'

const responses = await Promise.all([
	readJson<{ stargazers_count?: number }>(REPO_API, STARS_CACHE_TTL_SECONDS),
	readJson<{ downloads?: number }>(WEEKLY_DOWNLOADS_API, STATS_CACHE_TTL_SECONDS),
	readJson<{ downloads?: number }>(TOTAL_DOWNLOADS_API, STATS_CACHE_TTL_SECONDS),
])

const hasError = responses.some((response) => !response.success)
Astro.response.headers.set('Cache-Control', hasError ? 'no-store' : 'public, s-maxage=600, stale-while-revalidate=60')

const { data: repo } = responses[0]
const { data: weekly } = responses[1]
const { data: total } = responses[2]

const stats = {
	stars: formatStat(repo?.stargazers_count ?? 100),
	weeklyDownloads: formatStat(weekly?.downloads ?? null),
	totalDownloads: formatStat(total?.downloads ?? null),
}

export const prerender = false
---

<ul class="mt-0 flex h-16 w-fit items-center gap-3 px-4 lg:mb-0">
	<li class="flex min-w-0 items-end gap-2">
		<span class="text-secondary/70 h-6 w-6 shrink-0" set:html={StarSvg} />
		<span class="text-secondary/80 text-sm">{stats.stars}</span>
	</li>
	<li class="flex min-w-0 items-end gap-2">
		<span class="text-secondary/70 h-6 w-6 shrink-0" set:html={ChartSvg} />
		<span class="text-secondary/80 text-sm">{stats.weeklyDownloads}</span>
	</li>
	<li class="flex min-w-0 items-end gap-2">
		<span class="text-secondary/70 h-6 w-6 shrink-0" set:html={DownloadSvg} />
		<span class="text-secondary/80 text-sm">{stats.totalDownloads}</span>
	</li>
</ul>
