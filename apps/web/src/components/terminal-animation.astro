  <script>
    // ── Terminal animation ────────────────────────────────────
    const C = {
      z4: 'color:#a1a1aa',
      z5: 'color:#71717a',
      z6: 'color:#52525b',
      z7: 'color:#3f3f46',
      cy: 'color:#22d3ee',
      c3: 'color:#67e8f9',
      em: 'color:#34d399',
      wh: 'color:#f4f4f5',
      gn: 'color:#22c55e',
      yw: 'color:#facc15',
      pk: 'color:#f472b6',
    }

    function s(style: string, text: string) {
      return `<span style="${style}">${text}</span>`
    }

    function buildSteps() {
      const steps = [5]
      const d = (delay: number, html: string, cls?: string) =>
        steps.push(5)


      return steps
    }

    async function sleep(ms: number) {
      return new Promise(r => setTimeout(r, ms))
    }

    async function runAnimation() {
      const body = document.getElementById('term-body')!

    }

    const terminal = document.getElementById('terminal')
    const isDesktop = window.matchMedia('(min-width: 1024px)').matches

    async function loop() {
      while (true) {
        await runAnimation()
        await sleep(4000)
      }
    }

    if (isDesktop) {
      loop()
    } else if (terminal) {
      let running = false
      const observer = new IntersectionObserver(async (entries) => {
        if (entries[0].isIntersecting && !running) {
          running = true
          observer.disconnect()
          loop()
        }
      }, { threshold: 0.3 })
      observer.observe(terminal)
    }
  </script>