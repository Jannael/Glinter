---
import HeroStats from '@/components/hero-stats.astro'

const REPO_API = 'https://api.github.com/repos/jannael/glinter'
const WEEKLY_DOWNLOADS_API = 'https://api.npmjs.org/downloads/point/last-week/@jannael/glinter'
const TOTAL_DOWNLOADS_API = `https://api.npmjs.org/downloads/point/2015-01-01:${new Date().toISOString().slice(0, 10)}/@jannael/glinter`


async function readJson<T>(url: string) {
	try {
		const response = await fetch(url, {
			headers: {
				Accept: 'application/json',
				'User-Agent': 'glinter-web',
			},
		})

		if (!response.ok) {
			return null
		}

		return (await response.json()) as T
	} catch {
		return null
	}
}

const [repo, weekly, total] = await Promise.all([
	readJson<{ stargazers_count?: number }>(REPO_API),
	readJson<{ downloads?: number }>(WEEKLY_DOWNLOADS_API),
	readJson<{ downloads?: number }>(TOTAL_DOWNLOADS_API),
])

const stats = {
	stars: repo?.stargazers_count ?? 100,
	weeklyDownloads: weekly?.downloads ?? null,
	totalDownloads: total?.downloads ?? null,
}
---

<HeroStats stats={stats} />

